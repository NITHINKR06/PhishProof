# ============================================================
#  PhishProof — .gitignore
#  Java / Maven / Tomcat / IDE specific ignores
# ============================================================

# ── Maven build output ───────────────────────────────────────
target/
*.war
*.jar
*.class

# ── Maven wrapper ────────────────────────────────────────────
.mvn/wrapper/maven-wrapper.jar

# ── IDE — IntelliJ IDEA ──────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
out/

# ── IDE — Eclipse ────────────────────────────────────────────
.classpath
.project
.settings/
.factorypath
bin/

# ── IDE — VS Code ────────────────────────────────────────────
.vscode/
*.code-workspace

# ── IDE — NetBeans ───────────────────────────────────────────
nbproject/
nbbuild/
nbdist/
nb-configuration.xml

# ── OS files ─────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Sensitive config — NEVER commit these ────────────────────
# DB credentials / secrets
*.properties
application-local.properties
secrets.properties

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/
log/

# ── Tomcat local files ───────────────────────────────────────
work/
temp/
webapps/

# ── Environment files ────────────────────────────────────────
.env
.env.local
.env.production

# ── Docker ───────────────────────────────────────────────────
.dockerignore

# ── Misc ─────────────────────────────────────────────────────
*.tmp
*.bak
*.swp
*.orig
